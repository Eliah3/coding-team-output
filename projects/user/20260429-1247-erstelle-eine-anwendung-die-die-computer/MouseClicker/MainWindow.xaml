<Window x:Class="MouseClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maus-Klick Tool" Height="200" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status Anzeige -->
        <TextBlock Grid.Row="0" 
                   x:Name="StatusLabel" 
                   Text="Bereit" 
                   FontSize="24" 
                   HorizontalAlignment="Center" 
                   Foreground="Gray"
                   Margin="0,0,0,20"/>

        <!-- Start/Stop Button -->
        <Button Grid.Row="1" 
                x:Name="ToggleButton" 
                Content="Start" 
                Click="ToggleButton_Click"
                FontSize="16" 
                Padding="20,10"
                Background="#4CAF50"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                VerticalAlignment="Center"/>
        
        <!-- Fusszeile / Hinweis -->
        <TextBlock Grid.Row="2" 
                   Text="1 Klick pro Sekunde" 
                   FontSize="10" 
                   HorizontalAlignment="Center" 
                   Foreground="LightGray"/>
    </Grid>
</Window>